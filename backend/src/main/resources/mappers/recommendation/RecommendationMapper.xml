<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "https://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.ssafy.zipdaum.recommendation.mapper.RecommendationMapper">

  <resultMap id="propertyRecommendationCandidateResultMap"
             type="com.ssafy.zipdaum.recommendation.dto.PropertyRecommendationCandidate">
    <id property="id" column="id"/>
    <result property="propertyType" column="property_type"/>
    <result property="name" column="name"/>
    <result property="sggCd" column="sgg_cd"/>
    <result property="umdNm" column="umd_nm"/>
    <result property="jibun" column="jibun"/>
    <result property="buildYear" column="build_year"/>
    <result property="latestSalePrice" column="latest_sale_price"/>
    <result property="latestDeposit" column="latest_deposit"/>
    <result property="latestMonthlyRent" column="latest_monthly_rent"/>
    <result property="exclusiveArea" column="exclusive_area"/>
  </resultMap>

  <select id="selectPropertyRecommendationCandidate"
          resultMap="propertyRecommendationCandidateResultMap">
    SELECT
      p.id,
      p.property_type,
      p.name,
      p.sgg_cd,
      p.umd_nm,
      p.jibun,
      p.build_year,
      p.latest_sale_price,
      p.latest_deposit,
      p.latest_monthly_rent,
      (
        SELECT d.exclusive_area
        FROM (
          SELECT sd.exclusive_area, sd.deal_date, sd.id
          FROM sale_deal sd
          WHERE sd.property_id = p.id
          UNION ALL
          SELECT rd.exclusive_area, rd.deal_date, rd.id
          FROM rent_deal rd
          WHERE rd.property_id = p.id
        ) d
        ORDER BY d.deal_date DESC, d.id DESC
        LIMIT 1
      ) AS exclusive_area
    FROM property p
    WHERE p.id = #{propertyId}
  </select>
</mapper>
