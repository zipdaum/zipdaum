# Server
PORT=8080

# MySQL
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=zipdaum
MYSQL_USER=zipdaum
MYSQL_PASSWORD=change-me-user-password

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Mail
MAIL_USERNAME=change-me-google-email
MAIL_PASSWORD=change-me-google-app-password

# Public data and Kakao
PUBLIC_DATA_SERVICE_KEY=change-me-public-data-service-key
PUBLIC_DATA_CONNECT_TIMEOUT=5s
PUBLIC_DATA_READ_TIMEOUT=30s
KAKAO_REST_API_KEY=change-me-kakao-rest-api-key

# AI summary - SSAFY GMS OpenAI
GMS_KEY=change-me-gms-key
GMS_OPENAI_BASE_URL=https://gms.ssafy.io/gmsapi/api.openai.com
GMS_OPENAI_CHAT_COMPLETIONS_PATH=/v1/chat/completions
GMS_OPENAI_MODEL=gpt-5.5
GMS_OPENAI_CONNECT_TIMEOUT=5s
GMS_OPENAI_READ_TIMEOUT=30s

# JWT
JWT_SECRET=change-me-jwt-secret-key-at-least-32-bytes
JWT_ACCESS_TOKEN_EXPIRATION=3600000

# CORS
FRONTEND_ORIGINS=http://localhost:5173,https://zipdaum.vercel.app
FRONTEND_ORIGIN_PATTERNS=https://*.vercel.app
